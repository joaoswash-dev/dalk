# Banco de dados (Postgres)
DATABASE_URL="postgresql://dalk:dalk@localhost:5433/dalk?schema=public"

# JWT
JWT_SECRET="troque-esta-chave-em-producao"
JWT_REFRESH_SECRET="troque-esta-outra-chave-em-producao"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Servidor
PORT=3333
NODE_ENV="development"

# CORS — origem do frontend
WEB_ORIGIN="http://localhost:5173"

# Pagamento
# Provedor ativo: mock | asaas | stripe | mercadopago
PAYMENT_PROVIDER="mock"
PAYMENT_WEBHOOK_SECRET="segredo-do-webhook"
